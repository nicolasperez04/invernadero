# ============================================
# SIGMA - Backend Environment Variables
# Copy this file to .env and fill in values
# ============================================

# JWT Secret (base64-encoded, min 64 chars for HS256)
# Generate with: openssl rand -base64 64
JWT_SECRET=your-base64-encoded-jwt-secret-here-at-least-64-characters-long

# Database Connection
DB_URL=jdbc:postgresql://localhost:5432/invernadero
DB_USER=admin
DB_PASSWORD=your-db-password

# Server Port (default: 8080)
PORT=8080

# Irrigation System User (must exist in database)
IRRIGATION_SYSTEM_USER_EMAIL=admin@invernadero.com
